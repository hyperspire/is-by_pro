# PayPal REST API configuration
# Use sandbox URL for testing, production URL for live payments.
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Required credentials from developer.paypal.com app settings.
PAYPAL_CLIENT_ID=REPLACE_WITH_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_PAYPAL_CLIENT_SECRET

# Optional ad price in USD.
AD_PRICE_USD=25.00
